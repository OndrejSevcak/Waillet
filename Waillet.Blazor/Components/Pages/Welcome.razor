@page "/welcome"
@using Microsoft.FluentUI.AspNetCore.Components

<PageTitle>Welcome</PageTitle>

<div class="welcome-shell">
    <div class="user-menu">
        <FluentButton Appearance="Appearance.Stealth"
                      class="user-button"
                      IconStart="@(new Icons.Regular.Size20.Person())"
                      aria-haspopup="menu"
                      aria-expanded="@isUserMenuOpen.ToString().ToLower()"
                      aria-label="User menu"
                      OnClick="ToggleUserMenu" />
        @if (isUserMenuOpen)
        {
            <div class="user-dropdown"
                 role="menu"
                 @onkeydown="HandleDropdownKeyDown">
                <button type="button" class="dropdown-item" role="menuitem" @onclick="HandleLogout">
                    Logout
                </button>
            </div>
        }
    </div>
    <header class="welcome-banner">
        <div class="hero-badge">
            <span class="badge-dot"></span>
            Portfolio ready
        </div>
        <h1>Welcome to your Waillet hub</h1>
        <p>
            Your secure vault is ready. Create a wallet account to start holding and moving crypto assets.
        </p>
    </header>

    @if (assetsLoadError is not null)
    {
        <FluentMessageBar Intent="MessageIntent.Error">
            @assetsLoadError
            <FluentButton Appearance="Appearance.Stealth" OnClick="@(async () => { assetsLoadError = null; await OnInitializedAsync(); })">Retry</FluentButton>
        </FluentMessageBar>
    }

    @if (!showWalletForm)
    {
        <section class="welcome-stats">
            <div class="grid-card">
                <div class="grid-title">Network status</div>
                <div class="grid-value">All systems green</div>
            </div>
            <div class="grid-card">
                <div class="grid-title">Cold storage</div>
                <div class="grid-value">99.9% insured</div>
            </div>
            <div class="grid-card">
                <div class="grid-title">Settlement</div>
                <div class="grid-value">Instant internal</div>
            </div>
        </section>

        <section class="welcome-action">
            <div>
                <div class="action-title">Spin up your first wallet</div>
                <div class="action-copy">
                    Create separate accounts for each asset and track balances across your portfolio.
                </div>
            </div>
            <FluentButton Type="ButtonType.Button" class="primary-action" OnClick="HandleCreateWallet">
                Create wallet account
            </FluentButton>
        </section>
    }
    else
    {
        <section class="welcome-action welcome-action-form">
            <EditForm Model="createAccountModel" OnValidSubmit="HandleCreateWalletSubmitAsync">
                <DataAnnotationsValidator />
                <div class="action-title">Create wallet account</div>
                <div class="action-copy">
                    Pick the account type, currency, and opening balance for your new wallet.
                </div>
                <div class="wallet-form-grid">
                    <FluentSelect TOption="bool" Items="accountTypeOptions"
                                  OptionText="@(option => option ? "Crypto" : "Fiat")"
                                  OptionValue="@(option => option ? "Crypto" : "Fiat")"
                                  @bind-SelectedOption="createAccountModel.CryptoFlag"
                                  Label="Account type" />
                    <FluentSelect TOption="string" Items="currencyOptions"
                                  OptionText="@(option => option)"
                                  OptionValue="@(option => option)"
                                  @bind-SelectedOption="createAccountModel.CurrencyCode"
                                  Disabled="@(isAssetsLoading || currencyOptions.Count == 0)"
                                  Label="Currency" />
                    <ValidationMessage For="@(() => createAccountModel.CurrencyCode)" />
                </div>
                <div class="wallet-form-actions">
                    <FluentButton Type="ButtonType.Submit" class="primary-action" Disabled="isBusy">
                        Create account
                    </FluentButton>
                    <FluentButton Type="ButtonType.Button" Appearance="Appearance.Stealth" OnClick="HandleCancelCreateWallet">
                        Cancel
                    </FluentButton>
                </div>
            </EditForm>
        </section>
    }
</div>
