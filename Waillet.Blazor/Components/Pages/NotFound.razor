@page "/not-found"
@layout MainLayout

<PageTitle>Page Not Found — Waillet</PageTitle>

<div class="not-found-shell">
    <div class="not-found-code">404</div>
    <h1>Page not found</h1>
    <p>The page you're looking for doesn't exist or has been moved.</p>
    <a href="/login" class="not-found-link">Return to home</a>
</div>

<style>
    .not-found-shell {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        gap: 1rem;
        font-family: 'Space Grotesk', 'Segoe UI', system-ui, sans-serif;
        color: var(--waillet-ink, #e6f4ff);
        text-align: center;
    }

    .not-found-code {
        font-size: 6rem;
        font-weight: 700;
        color: var(--waillet-accent, #00e3bb);
        line-height: 1;
    }

    .not-found-shell h1 {
        font-size: 1.8rem;
        margin: 0;
    }

    .not-found-shell p {
        color: var(--waillet-muted, rgba(230, 244, 255, 0.7));
        margin: 0;
    }

    .not-found-link {
        margin-top: 0.5rem;
        padding: 0.6rem 1.4rem;
        border-radius: 999px;
        background: var(--waillet-accent, #00e3bb);
        color: #07101e;
        font-weight: 600;
        text-decoration: none;
    }

    .not-found-link:hover {
        opacity: 0.85;
    }
</style>